# Owncast Payment Sidecar Environment Variables Configuration Template
# Copy this file to '.env' and fill in your values.

# Streamer config
STREAMER_WALLET=0xb34432xxxxxxxxxxxx

# STREAMER_PRIVATE_KEY: Required for submitting checkout transactions on-chain.
# Never commit your real private key to git! Keep it local in your '.env' file.
STREAMER_PRIVATE_KEY=0xb34432xxxxxxxxxxxx

# Pricing / Rate per second in USD
RATE_PER_SECOND=0.0001

# Sidecar Server network config
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=8081

# Web3/Blockchain Config (Arc Testnet)
USDC_ARC_ADDRESS=0x3600000000000000000000000000000000000000
USDC_CHAIN_ID=5042002
ARC_RPC_URL=https://rpc.testnet.arc.network
